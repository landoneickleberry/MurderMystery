        if (c7 === "y") {
            updateScreen("main", story.p16);
            let c9 = await waitForChoice();

            if (c9 === "y") {
                updateScreen("main", story.p17);
                let c10 = await waitForChoice();
                updateScreen("main", c10 === "y" ? story.p18 : story.p19);
            } else {
                updateScreen("main", story.p20);
            }
        } else {
            updateScreen("main", story.p14);
        }
        return;
    }

    updateScreen("main", story.p13);
    let c8 = await waitForChoice();
    updateScreen("main", c8 === "y" ? story.p14 : story.p15);
}

