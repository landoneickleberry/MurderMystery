        updateScreen("main", story.p3);
        let c2 = await waitForChoice();

        if (c2 === "y") {
            updateScreen("main", story.p4);
            return;
        }

        updateScreen("main", story.p5);
        let c3 = await waitForChoice();

        if (c3 === "y") {
            updateScreen("main", story.p9);
            return;
        }

        updateScreen("main", story.p6);
        let c4 = await waitForChoice();

        if (c4 === "y") {
            updateScreen("main", story.p7);
            return;
        }

        updateScreen("main", story.p8);
        let c5 = await waitForChoice();

        if (c5 === "y") {
            updateScreen("main", story.p9);
        } else {
            updateScreen("main", story.p10);
        }
        return;
    }

    // ---- PATH 2: ROOM (p11) ----
    updateScreen("main", story.p11);
    let c6 = await waitForChoice();

    if (c6 === "y") {
        updateScreen("main", story.p12);
